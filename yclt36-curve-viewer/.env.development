# 生产环境配置
# VITE_APP_TITLE=YCLT36-典型电流流量测试曲线
# VITE_BASE_PATH=./
# VITE_API_URL=/api
# MODE=production

# API基础URL配置
# 由于部署在独立路径下，使用相对路径前缀
VITE_API_BASE_URL=http://localhost:5246

# 应用标题
VITE_APP_TITLE=我的应用程序

# 构建模式
VITE_BUILD_MODE=development

# 开启调试模式
VITE_DEBUG_MODE=true

# 开启Source Map便于调试
VITE_GENERATE_SOURCEMAP=true