# 生产环境配置
# VITE_APP_TITLE=YCLT36-典型电流流量测试曲线
# VITE_BASE_PATH=./
# VITE_API_URL=/api
# MODE=production

# API基础URL配置
# 由于部署在独立路径下，使用相对路径前缀
VITE_API_BASE_URL=http://192.168.1.110:90/api

# 应用标题
VITE_APP_TITLE=我的应用程序

# 构建模式
VITE_BUILD_MODE=production

# 关闭调试模式
VITE_DEBUG_MODE=false

# 生产环境不生成Source Map
VITE_GENERATE_SOURCEMAP=false

# 开启资源内联优化
VITE_INLINE_VITE_ASSETS=true

# 开启代码压缩
VITE_COMPRESS=true