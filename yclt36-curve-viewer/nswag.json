{
  "runtime": "Net80",
  "defaultVariables": null,
  "documentGenerator": {
    "fromDocument": {
      "url": "http://localhost:5246/swagger/v1/swagger.json",
      "output": null
    }
  },
  "codeGenerators": {
    "openApiToTypeScriptClient": {
      "className": "{controller}Service",
      "moduleName": "",
      "namespace": "",
      "typeScriptVersion": 4.0,
      "template": "Fetch",
      "promiseType": "Promise",
      "httpClass": "HttpClient",
      "useSingletonProvider": false,
      "injectionTokenType": "InjectionToken",
      "rxJsVersion": 6.0,
      "dateTimeType": "Date",
      "nullValue": "Undefined",
      "generateClientClasses": true,
      "generateClientInterfaces": false,
      "generateOptionalParameters": false,
      "exportTypes": true,
      "wrapDtoExceptions": false,
      "exposeJsonSerializerSettings": false,
      "clientBaseClass": null,
      "injectHttpClient": true,
      "disposeHttpClient": true,
      "protectedMethods": [],
      "configurationClass": null,
      "useHttpClientCreationMethod": false,
      "httpClientType": "HttpClient",
      "useTransformOptionsMethod": false,
      "useTransformResultMethod": false,
      "generateExceptionClasses": true,
      "exceptionClass": "ApiException",
      "useHttpClientMethods": false,
      "useObjectResultType": false,
      "generateConstructorInterface": true,
      "convertConstructorInterfaceData": false,
      "importRequiredTypes": true,
      "useGetBaseUrlMethod": false,
      "baseUrlTokenName": "API_BASE_URL",
      "queryNullValue": "",
      "classNamePrefix": "",
      "classNameSuffix": "Service",
      "operationGenerationMode": "MultipleClientsFromOperationId",
      "generateMultipleClients": true,
      "generateDtoTypes": true,
      "generateOptionalPropertiesAsNullable": false,
      "generateNullableReferenceTypes": false,
      "explicitNullableProperties": false,
      "generateKnownTypes": true,
      "generateEnumMapping": false,
      "generateEnumAsString": false,
      "enumNameGenerator": "PascalCase",
      "parameterNameGenerator": "PascalCase",
      "propertyNameGenerator": "PascalCase",
      "generateDefaultValues": true,
      "generateDataAnnotations": false,
      "generateRequiredPropertiesAsNonNullable": false,
      "generateSerializationMethods": false,
      "typeNameGenerator": "PascalCase",
      "schemaType": "OpenApi3",
      "generateCancellationToken": false,
      "generateRequestAndResponseClasses": true,
      "generateResponseClasses": true,
      "generateDtoInterfaces": false,
      "generateDtoIndexClass": true,
      "generateClientIndexClass": true,
      "clientIndexClass": "ApiClient",
      "dtoIndexClass": "ApiModels",
      "typeNamePrefix": "",
      "typeNameSuffix": "",
      "extensionCode": "",
      "generateOptionalProperties": true,
      "generateCatchAllProperty": false,
      "output": "src/api-generated/api.ts"
    }
  }
